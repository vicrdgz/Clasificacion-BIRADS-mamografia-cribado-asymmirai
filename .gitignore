# =============================================================
# .gitignore - TFM BI-RADS
# =============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
htmlcov/

# --- Entornos virtuales ---
venv/
env/
ENV/
.venv/
.env

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- IDE / editores ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Datos externos (no incluidos en el repositorio) ---
# VinDr-Mammo se descarga de PhysioNet bajo su propio DUA;
# los pesos de AsymMirai vienen del repositorio oficial.
Data/
AsymMirai/
*.dcm
*.dicom
*.pt
*.pth
*.ckpt
*.bin
*.safetensors

# --- Salidas experimentales pesadas ---
# Features extraidas (cientos de MB) y predicciones .npy no van al repo;
# la trazabilidad la aporta el codigo, no los binarios.
outputs/Features/
outputs/Predicciones/**/*.npy
outputs/Plots/*.png

# --- Logs y temporales ---
*.log
*.tmp
*.bak
*_ERROR.txt

# --- Comprimidos temporales del proyecto ---
*.zip
